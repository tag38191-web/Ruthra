        }
        @keyframes bg { 0% { background-position: 0% 50% } 100% { background-position: 100% 50% } }
        #welcome {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            background: #fff0f6;
            z-index: 1000;
            color: #ff4da6;
        }
        #name {
            font-size: 32px;
            font-weight: bold;
            opacity: 0;
            transform: scale(.5);
            animation: fadeIn 2s forwards;
        }
        #countdown { font-size: 28px; margin-top: 15px; color: #ff69b4; }
        @keyframes fadeIn { to { opacity: 1; transform: scale(1.2) } }
        #main { display: none; padding: 20px; position: relative; z-index: 1; }
        .card {
            background: rgba(255, 255, 255, 0.95);
            border-radius: 25px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,.2);
            max-width: 400px;
            margin: 50px auto;
            color: #333;
        }
        .slide {
            width: 140px;
            height: 140px;
            border-radius: 20px;
            border: 5px solid #ff69b4;
            object-fit: cover;
            box-shadow: 0 0 20px rgba(255,105,180,.6);
            position: absolute;
            left: 0; top: 0;
            transition: opacity 0.5s ease-in-out;
        }
        .message { font-size: 16px; margin-top: 15px; white-space: pre-line; color: #444; font-weight: 500; min-height: 100px; }
        button {
            margin-top: 20px;
            padding: 12px 25px;
            border: none;
            border-radius: 25px;
            background: linear-gradient(45deg, #ff69b4, #ff85c1);
            color: #fff;
            font-weight: bold;
            cursor: pointer;
            transition: transform 0.2s;
        }
        button:hover { transform: scale(1.1); }
        .heart { position: absolute; font-size: 18px; animation: float 6s linear infinite; z-index: 0; pointer-events: none; }
        @keyframes float { 0% { transform: translateY(100vh); opacity: 1; } 100% { transform: translateY(-10vh); opacity: 0; } }
        .sparkle { position: absolute; width: 6px; height: 6px; background: #fff; border-radius: 50%; animation: twinkle 1.2s infinite alternate; pointer-events: none; }
        @keyframes twinkle { from { opacity: .3; transform: scale(.8) } to { opacity: 1; transform: scale(1.3) } }
        #envelope {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) scale(0);
            width: 280px;
            height: 180px;
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.5);
            display: flex;
            justify-content: center;
            align-items: center;
